    { "source": "/api/psychrometric/",            "destination": "/api/index" },
    { "source": "/api/psychrometric",             "destination": "/api/index" },
    { "source": "/api/pump/",                     "destination": "/api/index" },
    { "source": "/api/pump",                      "destination": "/api/index" },
    { "source": "/api/rankine/",                  "destination": "/api/index" },
    { "source": "/api/rankine",                   "destination": "/api/index" },
